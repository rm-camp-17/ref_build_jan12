# HubSpot Private App Access Token
# Get this from: HubSpot Settings → Integrations → Private Apps
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Custom Object Type IDs
# These are the internal names for your custom objects in HubSpot
# Usually in format: p_{object_name}
HS_PROGRAM_OBJECT_TYPE=p_program
HS_SESSION_OBJECT_TYPE=p_session
HS_REFERRAL_OBJECT_TYPE=p_referral

# Referral Object Property Names (2025.02 Schema)
# Editable properties
HS_REFERRAL_KEY_PROP=referral_key
HS_REFERRAL_OUTREACH_PROP=referral_status
HS_REFERRAL_INTEREST_PROP=client_interest
HS_REFERRAL_NOTE_PROP=referral_note_to_company
HS_REFERRAL_PREVIOUSLY_SENT_PROP=previously_sent_to_camp

# Auto-managed properties
HS_REFERRAL_NAME_PROP=referral_name
HS_REFERRAL_COPIED_DEAL_KEY_PROP=copied_from_deal_key
HS_REFERRAL_COPIED_YEAR_PROP=copied_from_year

# Optional: Deal properties for metadata copying
# HS_DEAL_KEY_PROP=deal_key_property_name
# HS_DEAL_YEAR_PROP=deal_year_property_name

# ============================================================================
# Phase 3 middleware enforcement (UNIFIED_CARD_SPEC.md §5.1, §6.1)
# ============================================================================

# ce-billing's check-locked endpoint. When set, every mutating route checks
# whether the deal is commission_locked before writing sacred fields. If the
# var is unset, the requireUnlocked middleware soft-fails (logs a warning,
# allows the write) — so the codebase can ship before the ce-billing
# endpoint is deployed.
# CE_BILLING_API_URL=https://ce-billing.replit.app

# Shared secret sent as `X-Card-API-Key` header on the check-locked call.
# Optional — only needed if ce-billing requires it.
# CARD_API_KEY=replace-me

# When 'true', enables the requireDealAuthorization middleware in strict
# mode. Strict mode verifies HubSpot's X-HubSpot-Signature-v3 HMAC against
# the request and rejects unsigned / stale / tampered traffic. Defaults to
# off so dev/staging keeps working without the secret. NOTE: cross-deal
# bound-record verification is a Phase 4 follow-up — strict mode currently
# proves "this came from HubSpot" but not "this user is on this deal".
# STRICT_DEAL_AUTH=false

# HubSpot app client secret used for the X-HubSpot-Signature-v3 HMAC.
# Required when STRICT_DEAL_AUTH=true. Get this from the HubSpot Private
# App's settings page (NOT the access token — different value).
# HUBSPOT_CLIENT_SECRET=replace-me
